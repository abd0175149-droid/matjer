# ═══════════════ matjer — متغيّرات البيئة (قالب) ═══════════════
# انسخه إلى .env واضبط القيم الفعلية. لا ترفع .env إلى Git.

COMPOSE_PROJECT_NAME=matjer

# المنافذ (errata: كلها على 127.0.0.1 يصلها Cloudflare Tunnel)
FRONTEND_PORT=3020
BACKEND_PORT=4002
DB_PORT=5436
REDIS_PORT=6383

# قاعدة البيانات
DB_NAME=matjer_db
DB_PASSWORD=change_me_strong_db_password

# يحتاجه Prisma CLI خارج الحاوية أيضاً (errata C-12)
DATABASE_URL=postgresql://matjer_user:change_me_strong_db_password@127.0.0.1:5436/matjer_db

# المصادقة
JWT_SECRET=change_me_long_random_secret

# CORS (الدومين العام)
FRONTEND_URL=https://sooq.grade.sbs

# مستخدم المدير الأولي (يُنشئه السيد)
ADMIN_EMAIL=admin@matjer.local
ADMIN_PASSWORD=change_me_admin_password

# ═══ Firebase (الإشعارات + PWA Push) — اختياري، يُفعّل عند التعبئة ═══
# قيم الويب العامة (من Firebase Console → Project Settings → Web app)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_SENDER_ID=
FIREBASE_WEB_APP_ID=
# مفتاح VAPID (Cloud Messaging → Web Push certificates)
FIREBASE_WEB_VAPID_KEY=
# حساب الخدمة (Service Accounts → Generate new private key) — JSON مُرمّز base64 (سرّي)
FIREBASE_SERVICE_ACCOUNT_JSON=
